# .env.local — HireIQ Frontend Environment Variables
# Copy this file to .env.local and fill in the values
# NEVER commit .env.local to git

# ─── API Configuration ────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001

# ─── Azure AD B2C Authentication ──────────────────────────────────────────────
AZURE_AD_B2C_TENANT_ID=your-tenant-id-here
AZURE_AD_B2C_CLIENT_ID=your-client-id-here
AZURE_AD_B2C_CLIENT_SECRET=your-client-secret-here
AZURE_AD_B2C_PRIMARY_USER_FLOW=B2C_1_signup_signin
NEXTAUTH_SECRET=generate-a-random-secret-here
NEXTAUTH_URL=http://localhost:3000

# ─── For Production (Azure) ───────────────────────────────────────────────────
# NEXT_PUBLIC_API_URL=https://api.hireiq.ai
# NEXTAUTH_URL=https://app.hireiq.ai
