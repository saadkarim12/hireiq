# HireIQ Backend — .env
# Copy to .env and fill values

# ── Database ──────────────────────────────────────────────
DATABASE_URL="postgresql://hireiq:hireiq_dev_2026@localhost:5432/hireiq"

# ── Redis ─────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET="hireiq-jwt-secret-dev-2026-change-in-production"
JWT_EXPIRES_IN="8h"

# ── Anthropic (Claude API) ────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-your-key-here"

# ── WhatsApp (360dialog) ──────────────────────────────────
WHATSAPP_MODE="mock"
DIALOG360_API_KEY=""
DIALOG360_WEBHOOK_SECRET="mock-secret"

# ── Azure Blob Storage ────────────────────────────────────
AZURE_STORAGE_CONNECTION_STRING=""
AZURE_STORAGE_CONTAINER="cvfiles"

# ── Services ports ────────────────────────────────────────
CORE_API_PORT=3001
AI_ENGINE_PORT=3002
WHATSAPP_PORT=3003
SCHEDULER_PORT=3004

# ── CORS ──────────────────────────────────────────────────
FRONTEND_URL="http://localhost:3000"

# ── Environment ───────────────────────────────────────────
NODE_ENV="development"
