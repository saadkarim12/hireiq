{
  "name": "hireiq-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:ai\" \"npm run dev:wa\" \"npm run dev:scheduler\"",
    "dev:api":       "nodemon --watch src/core-api       --ext ts --exec ts-node src/core-api/index.ts",
    "dev:ai":        "nodemon --watch src/ai-engine      --ext ts --exec ts-node src/ai-engine/index.ts",
    "dev:wa":        "nodemon --watch src/whatsapp-service --ext ts --exec ts-node src/whatsapp-service/index.ts",
    "dev:scheduler": "nodemon --watch src/scheduler      --ext ts --exec ts-node src/scheduler/index.ts",
    "db:migrate":    "prisma migrate dev",
    "db:generate":   "prisma generate",
    "db:studio":     "prisma studio",
    "db:seed":       "ts-node prisma/seed.ts",
    "build":         "tsc",
    "typecheck":     "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk":   "^0.39.0",
    "@prisma/client":      "^5.22.0",
    "@aws-sdk/client-s3":  "^3.600.0",
    "axios":               "^1.7.2",
    "bcryptjs":            "^2.4.3",
    "cors":                "^2.8.5",
    "date-fns":            "^3.6.0",
    "dotenv":              "^16.4.5",
    "express":             "^4.19.2",
    "express-rate-limit":  "^7.4.0",
    "express-validator":   "^7.2.0",
    "helmet":              "^7.1.0",
    "jsonwebtoken":        "^9.0.2",
    "morgan":              "^1.10.0",
    "multer":              "^1.4.5-lts.1",
    "node-cron":           "^3.0.3",
    "redis":               "^4.7.0",
    "socket.io":           "^4.7.5",
    "uuid":                "^10.0.0",
    "winston":             "^3.14.2",
    "zod":                 "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs":     "^2.4.6",
    "@types/cors":         "^2.8.17",
    "@types/express":      "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan":       "^1.9.9",
    "@types/multer":       "^1.4.12",
    "@types/node":         "^20.0.0",
    "@types/node-cron":    "^3.0.11",
    "@types/uuid":         "^10.0.0",
    "concurrently":        "^9.0.1",
    "nodemon":             "^3.1.4",
    "prisma":              "^5.22.0",
    "ts-node":             "^10.9.2",
    "typescript":          "^5.5.4"
  }
}
